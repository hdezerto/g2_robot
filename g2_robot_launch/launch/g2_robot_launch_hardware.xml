<?xml version="1.0"?>
<launch>


    <!-- To disable printing of the output of the node to the terminal, remove the output="screen" attribute  -->
    
    <!--  Run the custom frames launch file  -->
    <include file="$(find-pkg-share g2_robot_launch)/launch/g2_robot_frames_launch.xml" />

    <!--  Run odometry node  -->
    <!--  output="screen" will print the output of the node to the terminal  -->
    <node pkg="odometry" exec="odometry" name="odometry_node" output="screen"/>

    <!--  Run motor peripherals and motors  -->
    <include file="$(find-pkg-share robp_launch)/launch/phidgets_launch.py"/>

    <!--  Run camera to initiate pointcloud  -->
    <include file="$(find-pkg-share robp_launch)/launch/rs_d435i_launch.py"/>

    <!--  Run Lidar  -->
    <include file="$(find-pkg-share robp_launch)/launch/lidar_launch.yaml"/>

     <!--  Run joystick teleop  -->
    <include file="$(find-pkg-share teleop_twist_joy)/launch/teleop-launch.py"> 
    <arg name="joy_config" value="xbox"/>
    </include>

    <!--  Run joystick controller  -->
    <node pkg="odometry" exec="controller" name="controller_node" output="screen"/>

    <!--  Run micro_ros_agent node  for the arm -->
    <node pkg="micro_ros_agent" exec="micro_ros_agent" name="micro_ros_agent_node" output="screen">
        <param name="arguments" value="serial --dev /dev/hiwonder_arm -v6"/>
    </node>

    <!--  Arm camera  -->
    <include file="$(find-pkg-share robp_launch)/launch/arm_camera_launch.yaml"/>


</launch>