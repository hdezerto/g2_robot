<?xml version="1.0"?>
<launch>


    <!-- To disable printing of the output of the node to the terminal, remove the output="screen" attribute  -->

    <!--  Run odometry node  -->
    <!-- output="screen" will print the output of the node to the terminal  -->
    <node pkg="path_planning" exec="point_publisher" name="point_publisher" output="screen"/>

    <node pkg="path_planning" exec="random_point" name="random_point" output="screen"/>

    <node pkg="path_planning" exec="path_planning" name="path_planning" output="screen"/>

    <node pkg="path_planning" exec="collection" name="collection" output="screen"/>






</launch>