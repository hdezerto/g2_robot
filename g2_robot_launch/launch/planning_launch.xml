<?xml version="1.0"?>
<launch>


    <!-- To disable printing of the output of the node to the terminal, remove the output="screen" attribute  -->

    <!--  Run the custom frames launch file  -->
    <include file="$(find-pkg-share g2_robot_launch)/launch/g2_robot_frames_launch.xml" />

    <!--  Run odometry node  -->
    <!--  output="screen" will print the output of the node to the terminal  -->
    <node pkg="odometry" exec="odometry" name="odometry" output="screen"/>

    <!--  Run motor peripherals and motors  -->
    <include file="$(find-pkg-share robp_launch)/launch/phidgets_launch.py"/>

    <!--  Run camera to initiate pointcloud  -->
    <!-- <include file="$(find-pkg-share robp_launch)/launch/rs_d435i_launch.py"/> -->

    <!--  Run RViz  -->
    <!--  ADD   args="-d $(find-pkg-share g2_robot)/rviz/g2_robot.rviz"    to load the g2_robot.rviz file  -->
    <node pkg="rviz2" exec="rviz2" name="rviz"/>

    <!--  Run joystick teleop  -->
    <!-- <include file="$(find-pkg-share teleop_twist_joy)/launch/teleop-launch.py">  -->
    <!-- <arg name="joy_config" value="xbox"/> -->
    <!-- </include> -->

    <!--  Run joystick controller  -->
    <!-- <node pkg="odometry" exec="controller" name="controller" output="screen"/> -->

    <!--  Run detection  -->
    <!-- <node pkg="detection" exec="detection" name="detection" output="screen"/> -->

    <!--  Run Lidar stabilizer  -->
    <!-- <node pkg="odometry" exec="lidar_cloud" name="lidar_cloud" output="screen"/> -->

    <!--  Run Object Mapping  -->
    <!-- <node pkg="detection" exec="object_mapping" name="object_mapping" output="screen"/> -->

    <!-- Run Point Publisher -->
    <node pkg="path_planning" exec="point_publisher" name="point_publisher" output="screen"/>

    <!--  Run Path Follower  -->
    <node pkg="odometry" exec="path_follower" name="path_follower" output="screen"/>

    <node pkg="path_planning" exec="point_publisher" name="point_publisher" output="screen"/>

    <node pkg="path_planning" exec="random_point" name="random_point" output="screen"/>

    <node pkg="path_planning" exec="path_planning" name="path_planning" output="screen"/>

    <node pkg="path_planning" exec="collection" name="collection" output="screen"/>





</launch>