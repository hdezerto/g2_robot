<?xml version="1.0"?>
<launch>


    <!-- To disable printing of the output of the node to the terminal, remove the output="screen" attribute  -->
    <!-- The name defined for the node here will overwrite the name defined in the node itself  -->

    <!--  Run odometry node  -->
    <!--  output="screen" will print the output of the node to the terminal  -->
    <node pkg="odometry" exec="odometry" name="odometry_node" output="screen"/>


    <!-- Run arm controller -->
    <node pkg="manipulation" exec="arm_controller" name="arm_controller_node" output="screen"/>


    <include file="$(find-pkg-share g2_robot_launch)/launch/planning_launch.xml" />


</launch>