<?xml version="1.0"?>
<launch>

    <!-- Static transforms from frames_launch.xml -->
    <node name="base_to_imu" pkg="tf2_ros" exec="static_transform_publisher" args="--x 0.00107 --y 0 --z 0.02361 --frame-id base_link --child-frame-id imu_link" />
    <node name="base_to_rs_d435i" pkg="tf2_ros" exec="static_transform_publisher" args="--x 0.08987 --y 0.0175 --z 0.10456 --frame-id base_link --child-frame-id camera_link" />

    <!-- Additional static transforms -->
    <node name="base_to_lidar" pkg="tf2_ros" exec="static_transform_publisher" args="--x 0.00587 --y 0.1005 --z 0.14456 --frame-id base_link --child-frame-id lidar_link" />
    <node name="map_to_odom" pkg="tf2_ros" exec="static_transform_publisher" args="--x 0 --y 0 --z 0 --frame-id map --child-frame-id odom" />

    <!-- Static transform publisher for odometry -->
